{
    "name": "@archlens/parser",
    "version": "0.1.0",
    "description": "TypeScript/JavaScript structural parser for ArchLens",
    "type": "module",
    "exports": {
        ".": {
            "import": "./dist/index.js",
            "require": "./dist/index.cjs",
            "types": "./dist/index.d.ts"
        }
    },
    "main": "./dist/index.cjs",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "files": [
        "dist"
    ],
    "scripts": {
        "build": "tsup",
        "test": "vitest run",
        "clean": "rm -rf dist",
        "typecheck": "tsc --noEmit"
    },
    "dependencies": {
        "@archlens/types": "workspace:*",
        "@archlens/shared": "workspace:*",
        "ts-morph": "^24.0.0"
    },
    "devDependencies": {
        "tsup": "^8.3.0",
        "typescript": "^5.7.0",
        "vitest": "^3.0.0"
    }
}
